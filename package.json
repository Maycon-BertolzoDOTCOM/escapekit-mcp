{
  "name": "escapekit",
  "version": "1.0.0",
  "description": "EscapeKit: Transform AI sandbox code into production-ready projects. Detects ghost dependencies, auto-fixes imports, validates builds, and deploys with confidence.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "escapekit": "./bin/escapekit"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "node dist/server.js",
    "cli": "tsx cli/index.ts",
    "test": "vitest",
    "test:ci": "vitest --coverage --run",    
    "test:coverage": "vitest --coverage",
    "test:systemeval": "bash .comate/systemeval/run-systemeval.sh",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "paper-to-contract": "./scripts/paper-to-contract.sh",
    "health-check": "./scripts/health-check.sh",
    "validate-contracts": "./scripts/validate-contracts.sh",
    "generate-tests": "tsx scripts/generate-tests.ts",
    "deploy:railway": "./scripts/deploy-to-railway.sh",
    "test:deployment": "./scripts/test-deployment.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "sandbox",
    "code-generation",
    "escape",
    "portability",
    "developer-tools",
    "cli",
    "validation",
    "auto-fix",
    "production-ready"
  ],
  "author": "EscapeKit Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "commander": "^12.0.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.58.2",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.11.0",
    "@types/xmlrpc": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.6.0",
    "handlebars": "^4.7.8",
    "ink": "^4.4.1",
    "prettier": "^3.2.4",
    "react": "^18.2.0",
    "recast": "^0.23.11",
    "tree-sitter": "^0.25.0",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "xmlrpc": "^1.3.2",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/escapekit/escapekit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/escapekit/escapekit-mcp/issues"
  },
  "homepage": "https://github.com/escapekit/escapekit-mcp#readme"
}
