{
  "name": "escapekit-mcp",
  "version": "2.0.0",
  "description": "EscapeKit: Breaking Ralph Loop Inverso - Transform AI sandbox code into production-ready projects",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "escapekit": "./cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "cli": "tsx cli/index.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "paper-to-contract": "./scripts/paper-to-contract.sh",
    "health-check": "./scripts/health-check.sh",
    "validate-contracts": "./scripts/validate-contracts.sh"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "sandbox",
    "code-generation",
    "escape",
    "portability"
  ],
  "author": "EscapeKit Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.58.2",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.6.0",
    "prettier": "^3.2.4",
    "recast": "^0.23.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/escapekit/escapekit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/escapekit/escapekit-mcp/issues"
  },
  "homepage": "https://github.com/escapekit/escapekit-mcp#readme"
}
