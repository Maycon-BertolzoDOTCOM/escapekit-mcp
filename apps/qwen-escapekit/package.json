{
  "name": "qw-escapekit-cli",
  "version": "2.0.0",
  "description": "CLI para automatizar fluxo de Paper para Contrato Factual no ecossistema EscapeKit",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "qwen-escapekit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "escapekit",
    "qwen",
    "qwen-code",
    "ollama",
    "cli",
    "factual-contracts",
    "security",
    "research",
    "automation",
    "ai-safety",
    "paper-to-code",
    "knowledge-base"
  ],
  "author": "EscapeKit Team",
  "license": "MIT",
  "dependencies": {
    "@escapekit/core": "*",
    "axios": "^1.6.7",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "ink": "^4.4.1",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ora": "^3.1.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.2.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/escapekit/escapekit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/escapekit/escapekit-mcp/issues"
  },
  "homepage": "https://github.com/escapekit/escapekit-mcp/tree/main/qwen-escapekit#readme",
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "publishConfig": {
    "access": "public"
  }
}
