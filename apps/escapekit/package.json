{
  "name": "@escapekit/core",
  "version": "1.0.0",
  "description": "EscapeKit MCP — analyze AI sandbox code, detect ghost dependencies, transform and validate in real environments",
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./cli": "./dist/cli/index.js"
  },
  "bin": {
    "escapekit": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest --run",
    "test:ci": "vitest --run --coverage",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@playwright/test": "^1.58.2",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.0.0",
    "handlebars": "^4.7.8",
    "recast": "^0.23.11",
    "tsx": "^4.7.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "fast-check": "^4.6.0"
  },
  "files": ["dist/", "README.md", "package.json"],
  "engines": {
    "node": ">=18.0.0"
  }
}
