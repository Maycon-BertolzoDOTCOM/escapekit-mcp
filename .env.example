# Kiwi TCMS Configuration
# Copy this file to .env and fill in your actual values

# Kiwi TCMS instance URL
KIWI_URL=https://your-kiwi-tcms-instance.com

# API credentials
KIWI_USERNAME=your-username
KIWI_PASSWORD=your-password

# Optional: Product ID in Kiwi TCMS
# KIWI_PRODUCT_ID=123

# Optional: Test Plan ID in Kiwi TCMS
# KIWI_TEST_PLAN_ID=456

# Optional: Enable verbose logging
# VERBOSE=false

# Optional: Dry run mode (validate without uploading)
# DRY_RUN=false
