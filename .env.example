# Kiwi TCMS Configuration
# Copy this file to .env and fill in your actual values

# Kiwi TCMS instance URL
KIWI_URL=https://your-kiwi-tcms-instance.com

# API credentials
KIWI_USERNAME=your-username
KIWI_PASSWORD=your-password

# Optional: Test Plan ID in Kiwi TCMS
# KIWI_TEST_PLAN_ID=456

# Optional: Product name (default: EscapeKit)
# KIWI_PRODUCT_NAME=EscapeKit

# Optional: Enable verbose logging
# VERBOSE=false

# Optional: Enable JSON structured logs (for CI/CD)
# KIWI_JSON_LOGS=false

# ─── Slack Notifications ─────────────────────────────────

# Optional: Slack webhook URL for test result notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Optional: Slack channel override
# SLACK_CHANNEL=#ci-results

# Optional: Bot username (default: EscapeKit)
# SLACK_USERNAME=EscapeKit

# ─── Jira Integration ───────────────────────────────────

# Optional: Jira base URL
# JIRA_BASE_URL=https://your-org.atlassian.net

# Optional: Jira email for API auth
# JIRA_EMAIL=user@example.com

# Optional: Jira API token
# JIRA_API_TOKEN=your-api-token

# Optional: Jira project key
# JIRA_PROJECT_KEY=ESC
